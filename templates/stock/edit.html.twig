{% extends 'base.html.twig' %}

{% block title %}
	{{ stock.product.name }}
{% endblock %}

{% block body %}
	<div class="my-10">
		<div class="max-w-2xl mx-auto bg-white p-8 rounded-xl shadow space-y-6">

			{{ form_start(form, { method: 'POST', attr: { class: 'space-y-6' } }) }}

			{# HEADER CONTEXTUEL #}
			<div class="border-b pb-4 space-y-1">
				<h1 class="text-lg font-semibold text-slate-900">
					{{ stock.product.name }}
				</h1>

				<p class="text-sm text-slate-500">
					Entrepôt :
					<span class="font-medium text-slate-700">
						{{ stock.warehouse.name }}
					</span>
				</p>
			</div>

			{# QUANTITY FIELD #}
			<div>
				{{ form_label(form.quantity, 'Quantité', {
				label_attr: {
					class: 'block text-sm font-medium text-slate-700 mb-1'
				}
			}) }}

				{{ form_widget(form.quantity, {
				attr: {
					class: 'w-full px-3 py-2 rounded-lg border border-slate-300 focus:border-indigo-500 focus:ring-indigo-500'
				}
			}) }}

				<div class="mt-1 text-sm text-red-600">
					{{ form_errors(form.quantity) }}
				</div>
			</div>

			{# BUTTON #}
			<div class="pt-2">
				{{ form_widget(form.save, {
				attr: {
					class: 'w-full bg-indigo-600 text-white font-semibold py-2 px-4 rounded-lg hover:bg-indigo-700 transition'
				}
			}) }}
			</div>

			{{ form_rest(form) }}
			{{ form_end(form) }}


			<div class="border-t pt-6">
				<h2 class="text-lg font-semibold text-slate-900 mb-4">
					Stocks du produit par entrepôt
				</h2>

				<div class="overflow-hidden rounded-lg border border-slate-200">
					<table class="min-w-full divide-y divide-slate-200">
						<thead class="bg-slate-100">
							<tr>
								<th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">
									Entrepôt
								</th>
								<th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-slate-600">
									Quantité
								</th>
							</tr>
						</thead>

						<tbody class="divide-y divide-slate-100 bg-white">
							{% for s in stockByWarehouse %}
								<tr class="hover:bg-slate-50">
									<td class="px-4 py-3 text-slate-700">
										{{ s.warehouse.name }}
									</td>

									<td class="px-4 py-3 text-right font-medium text-slate-900">
										{{ s.quantity }}
									</td>
								</tr>
							{% else %}
								<tr>
									<td colspan="2" class="px-4 py-6 text-center text-slate-500">
										Aucun stock trouvé.
									</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
