{% extends 'base.html.twig' %}

{% block title %}
	Entrepôts
{% endblock %}

{% block body %}
	<div class="overflow-x-auto px-4 md:px-8 mt-6">

		<a href="{{ path('warehouse.create') }}" class="inline-flex items-center gap-2 px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg shadow hover:bg-indigo-700 transition">
			+ Ajouter un entrepôt
		</a>

		<table class="w-full max-w-7xl mx-auto mt-4">
			<thead class="text-slate-900 text-left text-sm font-semibold border-b border-slate-300 whitespace-nowrap">
				<tr>
					<th scope="col" class="pl-0 px-3 py-3.5">
						Nom
					</th>
					<th scope="col" class="px-3 py-3.5">
						Adresse
					</th>
					<th scope="col" class="pr-0 px-3 py-3.5">
						Actions
					</th>
				</tr>
			</thead>

			<tbody class="text-sm divide-y divide-slate-200">
				{% for w in warehouses %}
					<tr>
						<td class="pl-0 px-3 py-4 font-medium text-slate-900 whitespace-nowrap">
							{{ w.name }}
						</td>

						<td class="px-3 py-4 text-slate-500">
							{{ w.address }}
						</td>

						<td
							class="pr-0 px-3 py-4 flex gap-2">

							{# Voir #}
							<a href="{{ path('warehouse.detail', {id: w.id, slug: w.slug}) }}" class="w-9 h-9 flex items-center justify-center bg-indigo-600 text-white rounded-lg shadow hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500" title="Voir le détail">
								<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>

									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5
																																																						                                             c4.478 0 8.268 2.943 9.542 7
																																																						                                             -1.274 4.057-5.064 7-9.542 7
																																																						                                             -4.477 0-8.268-2.943-9.542-7z"/>
								</svg>
							</a>

							{# Modifier #}
							<a href="{{ path('warehouse.edit', {id: w.id, slug: w.slug}) }}" class="w-9 h-9 flex items-center justify-center bg-blue-600 text-white rounded-lg shadow hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500" title="Modifier">
								<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5"/>

									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
								</svg>
							</a>

							{# Supprimer #}
							<form action="{{ path('warehouse.delete', {id: w.id}) }}" method="post">
								<input type="hidden" name="_method" value="DELETE"/>
								<button type="submit" class="w-9 h-9 flex items-center justify-center bg-red-600 text-white rounded-lg shadow hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 cursor-pointer" title="Supprimer">
									<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
									</svg>
								</button>
							</form>
						</td>
					</tr>
				{% else %}
					<tr>
						<td colspan="3" class="py-6 text-center text-slate-500">
							Aucun entrepôt trouvé.
						</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>

	</div>
{% endblock %}
