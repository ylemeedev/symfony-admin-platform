<div class="max-w-2xl mx-auto bg-white p-8 rounded-xl shadow space-y-6">

    {{ form_start(form, {
        method: 'POST',
        attr: {
            class: 'space-y-6'
        }
    }) }}

    <div>
        {{ form_label(form.name, 'Nom', {
            label_attr: {
                class: 'block text-sm font-medium text-gray-700 mb-1'
            }
        }) }}

        {{ form_widget(form.name, {
            attr: {
                class: 'w-full px-3 py-2 rounded-lg border border-gray-300 focus:border-indigo-500 focus:ring-indigo-500'
            }
        }) }}

        {{ form_errors(form.name) }}
    </div>

    <div>
        {{ form_label(form.email, 'Email', {
            label_attr: {
                class: 'block text-sm font-medium text-gray-700 mb-1'
            }
        }) }}

        {{ form_widget(form.email, {
            attr: {
                class: 'w-full px-3 py-2 rounded-lg border border-gray-300 focus:border-indigo-500 focus:ring-indigo-500'
            }
        }) }}

        {{ form_errors(form.email) }}
    </div>

    <div>
        {{ form_label(form.phone, 'Téléphone', {
            label_attr: {
                class: 'block text-sm font-medium text-gray-700 mb-1'
            }
        }) }}

        {{ form_widget(form.phone, {
            attr: {
                class: 'w-full px-3 py-2 rounded-lg border border-gray-300 focus:border-indigo-500 focus:ring-indigo-500',
                rows: 3
            }
        }) }}

        {{ form_errors(form.phone) }}
    </div>

    <div class="pt-4">
        {{ form_widget(form.save, {
            attr: {
                class: 'w-full bg-indigo-600 text-white font-semibold py-2 px-4 rounded-lg hover:bg-indigo-700 transition cursor-pointer'
            }
        }) }}
    </div>

    {{ form_rest(form) }}

    {{ form_end(form) }}

</div>