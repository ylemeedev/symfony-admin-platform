{% if pageCount > 1 %}
    <nav class="flex items-center justify-center mt-6">
        <ul class="inline-flex items-center gap-1">

            {# Précédent #}
            {% if previous is defined %}
                <li>
                    <a href="{{ path(route, query|merge({(pageParameterName): previous})) }}"
                       class="px-3 py-2 text-sm font-medium text-slate-700 bg-white border border-slate-300 rounded-lg hover:bg-slate-100 transition">
                        ←
                    </a>
                </li>
            {% else %}
                <li>
                    <span class="px-3 py-2 text-sm font-medium text-slate-400 bg-slate-100 border border-slate-200 rounded-lg cursor-not-allowed">
                        ←
                    </span>
                </li>
            {% endif %}

            {# Pages #}
            {% for page in pagesInRange %}
                <li>
                    {% if page == current %}
                        <span class="px-3 py-2 text-sm font-semibold text-white bg-indigo-600 border border-indigo-600 rounded-lg">
                            {{ page }}
                        </span>
                    {% else %}
                        <a href="{{ path(route, query|merge({(pageParameterName): page})) }}"
                           class="px-3 py-2 text-sm font-medium text-slate-700 bg-white border border-slate-300 rounded-lg hover:bg-slate-100 transition">
                            {{ page }}
                        </a>
                    {% endif %}
                </li>
            {% endfor %}

            {# Suivant #}
            {% if next is defined %}
                <li>
                    <a href="{{ path(route, query|merge({(pageParameterName): next})) }}"
                       class="px-3 py-2 text-sm font-medium text-slate-700 bg-white border border-slate-300 rounded-lg hover:bg-slate-100 transition">
                        →
                    </a>
                </li>
            {% else %}
                <li>
                    <span class="px-3 py-2 text-sm font-medium text-slate-400 bg-slate-100 border border-slate-200 rounded-lg cursor-not-allowed">
                        →
                    </span>
                </li>
            {% endif %}

        </ul>
    </nav>
{% endif %}