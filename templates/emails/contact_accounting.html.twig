<!DOCTYPE html>
<html>
	<body style="font-family: Arial, sans-serif; background:#f9fafb; padding:20px;">

		<div style="max-width:600px;margin:auto;background:#fff;padding:20px;border-radius:10px;border:1px solid #e5e7eb;">

			<h2 style="color:#dc2626;">💰 Notification Comptabilité</h2>

			<p>
				<strong>Nom :</strong>
				{{ data.name }}</p>
			<p>
				<strong>Email :</strong>
				{{ data.email }}</p>

			<hr style="margin:20px 0;">

			<p>
				<strong>Détail :</strong>
			</p>
			<div style="background:#fef2f2;padding:15px;border-radius:6px;white-space:pre-line;">
				{{ data.message }}
			</div>

			<p style="margin-top:20px;color:#6b7280;font-size:12px;">
				Vérification requise par le service comptabilité.
			</p>

		</div>

	</body>
</html>
