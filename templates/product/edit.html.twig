{% extends 'base.html.twig' %}

{% block title %}
	{{ product.name }}
{% endblock %}

{% block body %}
	<div class="my-6">
		<div class="max-w-2xl mx-auto bg-white p-8 rounded-xl shadow space-y-6">
			{% include './product/form.html.twig' %}

			<div class="border-t pt-6">
				<h2 class="text-lg font-semibold text-slate-900 mb-4">
					Stocks du produit par entrepôt
				</h2>

				<div class="overflow-hidden rounded-lg border border-slate-200">
					<table class="min-w-full divide-y divide-slate-200">
						<thead class="bg-slate-100">
							<tr>
								<th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">
									Entrepôt
								</th>
								<th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-slate-600">
									Quantité
								</th>
								<th></th>
							</tr>
						</thead>

						<tbody class="divide-y divide-slate-100 bg-white">
							{% for s in product.stocks %}
								<tr class="hover:bg-slate-50">
									<td class="px-4 py-3 text-slate-700">
										{{ s.warehouse.name }}
									</td>

									<td class="px-4 py-3 text-right font-medium text-slate-900">
										{{ s.quantity }}
									</td>

									<td class="px-4 py-3 text-right font-medium text-slate-900">
										<a href="{{ path('stock.edit', {id: s.id}) }}" class="w-9 h-9 flex items-center justify-center bg-blue-600 text-white rounded-lg shadow hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500" title="Modifier">
											<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5"/>
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
											</svg>
										</a>
									</td>
								</tr>
							{% endfor %}

							{% if canAddWarehouse %}
							<tr>
								<td colspan="3" class="px-4 py-6 text-center text-slate-500">
									<a href="{{ path('stock.create', {id: product.id}) }}" class="inline-flex items-center gap-2 px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg shadow hover:bg-indigo-700 transition">
										+ Ajouter le produit en stock
									</a>
								</td>
							</tr>
							{% endif %}
						</tbody>
					</table>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
