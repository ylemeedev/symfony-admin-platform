{% extends 'base.html.twig' %}

{% block title %}
	{{ product.name }}
{% endblock %}

{% block body %}
	<div class="max-w-4xl mx-auto px-4 py-8">
		<div class="bg-white shadow-lg rounded-2xl p-6">
			<h1 class="text-3xl font-bold text-gray-900 mb-4">
				{{ product.name }}
			</h1>

			<div class="mb-6">
				<p class="text-gray-600 leading-relaxed">
					ref:
					{{ product.reference }}
				</p>
			</div>

			<div class="mb-6">
				<span class="text-2xl font-semibold text-green-600">
					{{ product.price }}
					€
				</span>
			</div>

			<div class="mb-6">
				<h2 class="text-lg font-semibold text-gray-800 mb-2">
					Description
				</h2>
				<p class="text-gray-600 leading-relaxed">
					{{ product.description }}
				</p>
			</div>

			<div class="mb-6">
				<div class="border-t pt-6">
					<h2 class="text-lg font-semibold text-slate-900 mb-4">
						Stocks du produit par entrepôt
					</h2>

					<div class="overflow-hidden rounded-lg border border-slate-200">
						<table class="min-w-full divide-y divide-slate-200">
							<thead class="bg-slate-100">
								<tr>
									<th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">
										Entrepôt
									</th>
									<th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-slate-600">
										Quantité
									</th>
								</tr>
							</thead>

							<tbody class="divide-y divide-slate-100 bg-white">
								{% for s in product.stocks %}
									<tr class="hover:bg-slate-50">
										<td class="px-4 py-3 text-slate-700">
											{{ s.warehouse.name }}
										</td>

										<td class="px-4 py-3 text-right font-medium text-slate-900">
											{{ s.quantity }}
										</td>
									</tr>
								{% else %}
									<tr>
										<td colspan="2" class="px-4 py-6 text-center text-slate-500">
											Aucun stock trouvé.
										</td>
									</tr>
								{% endfor %}
							</tbody>
						</table>
					</div>
				</div>
			</div>

			<div class="border-t pt-4">
				<div class="flex items-center justify-between">
					<span class="text-gray-700 font-medium">
						Stock minimum
					</span>
					<span class="inline-flex items-center px-3 py-1 rounded-full bg-blue-100 text-	blue-800 text-sm font-medium">
						{{ product.minimumStock }}
					</span>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
