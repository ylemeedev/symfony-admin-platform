{% extends 'base.html.twig' %}

{% block title %}Contactez-nous
{% endblock %}

{% block body %}
	<div class="max-w-2xl mx-auto py-12 px-4">

		<h1 class="text-3xl font-bold mb-8 text-gray-900">
			Contactez-nous
		</h1>

		{{ form_start(form) }}

		<div class="space-y-6">

			<div>
				{{ form_label(form.name, 'Nom', {
                label_attr: {
                    class: 'block mb-2 text-sm font-medium text-gray-700'
                }
            }) }}

				{{ form_widget(form.name, {
                attr: {
                    class: 'w-full border border-gray-300 rounded-lg px-4 py-2 focus:border-blue-500 focus:ring focus:ring-blue-200'
                }
            }) }}

				{{ form_errors(form.name) }}
			</div>

			<div>
				{{ form_label(form.email, 'E-mail', {
                label_attr: {
                    class: 'block mb-2 text-sm font-medium text-gray-700'
                }
            }) }}

				{{ form_widget(form.email, {
                attr: {
                    class: 'w-full border border-gray-300 rounded-lg px-4 py-2 focus:border-blue-500 focus:ring focus:ring-blue-200'
                }
            }) }}

				{{ form_errors(form.email) }}
			</div>

			<div>
				{{ form_label(form.message, 'Message', {
                label_attr: {
                    class: 'block mb-2 text-sm font-medium text-gray-700'
                }
            }) }}

				{{ form_widget(form.message, {
                attr: {
                    class: 'w-full border border-gray-300 rounded-lg px-4 py-2 min-h-40 focus:border-blue-500 focus:ring focus:ring-blue-200'
                }
            }) }}

				{{ form_errors(form.message) }}
			</div>


			<div class="pt-4">
				{{ form_widget(form.send, {
			attr: {
				class: 'w-full bg-indigo-600 text-white font-semibold py-2 px-4 rounded-lg hover:bg-indigo-700 transition'
			}
		}) }}
			</div>

		</div>

		{{ form_end(form) }}

	</div>
{% endblock %}
